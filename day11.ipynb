   "source": [
    "1. Write a function that pushes every value onto a stack, then drain it with.pop(), summing as it goes. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b0c67508",
   "metadata": {},
   "outputs": [],
   "source": [
    "def sum_stack(numbers):\n",
    "    stack = []\n",
    "    for num in numbers:\n",
    "        stack.append(num)\n",
    "\n",
    "    total = 0\n",
    "    while stack:\n",
    "        total += stack.pop()\n",
    "    return total\n",
    "\n"
   ]
  }
 ],
